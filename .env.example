# Azure Threat Lens – Environment Variables
# Copy this file to .env and fill in your values.
# All variables use the ATL_ prefix.

# ── Secret source mode ────────────────────────────────────────────────────────
# local: secrets are read from this .env file (recommended only for dev/test)
# keyvault: secrets are loaded from Azure Key Vault at runtime (recommended for prod)
ATL_SECRET_SOURCE=local  # local | keyvault
ATL_KEYVAULT_URI=
# Optional JSON map: settings path -> key vault secret name
# ATL_KEYVAULT_SECRET_MAP={"azure.client_secret":"atl-azure-client-secret","llm.openai_api_key":"atl-openai-key"}
ATL_KEYVAULT_SECRET_MAP={}

# ── Azure App Registration / User auth (required) ────────────────────────────
ATL_AZURE_TENANT_ID=
ATL_AZURE_CLIENT_ID=
ATL_AZURE_CLIENT_SECRET=
ATL_AZURE_SUBSCRIPTION_ID=
ATL_AZURE_AUTH_MODE=service_principal  # service_principal | user

# ── Microsoft Sentinel (required) ─────────────────────────────────────────────
ATL_SENTINEL_WORKSPACE_ID=
ATL_SENTINEL_WORKSPACE_NAME=
ATL_SENTINEL_RESOURCE_GROUP=

# ── Breach Manager (enterprise multi-tenant) ─────────────────────────────────
ATL_BM_DEFAULT_AUTH_STRATEGY=service_principal  # service_principal | user
ATL_BM_TENANT_IDS=[]  # JSON list, e.g. ["tenant-a-guid","tenant-b-guid"]
ATL_BM_USE_LIGHTHOUSE=false
# Planned integrations JSON list:
# ATL_BM_FUTURE_APIS=[{"name":"Attack Path Graph API","enabled":true,"endpoint_env_var":"ATL_BM_ATTACK_PATH_API_URL","token_env_var":"ATL_BM_ATTACK_PATH_API_TOKEN","notes":""}]
ATL_BM_ATTACK_PATH_API_URL=
ATL_BM_ATTACK_PATH_API_TOKEN=
ATL_BM_ORCHESTRATOR_API_URL=
ATL_BM_ORCHESTRATOR_API_TOKEN=
# Optional in-app custom skill definitions (JSON list)
# ATL_BM_LOCAL_SKILLS=[{"id":"skill.custom.sap","name":"SAP Breach Skill","category":"app","purpose":"Respond to SAP compromise","trigger_terms":["sap"],"playbooks_supported":["SAP App Compromise"]}]
ATL_BM_LOCAL_SKILLS=[]

# ── Threat Intelligence (optional – enables enrichment) ───────────────────────
ATL_VIRUSTOTAL_API_KEY=
ATL_GREYNOISE_API_KEY=
ATL_ABUSEIPDB_API_KEY=

# ── Azure OpenAI / LLM (optional – enables AI-assisted analysis) ──────────────
ATL_LLM_ENDPOINT=
ATL_LLM_DEPLOYMENT=
ATL_LLM_API_VERSION=
ATL_OPENAI_API_KEY=
ATL_ANTHROPIC_API_KEY=

# ── Microsoft Defender XDR (optional) ─────────────────────────────────────────
ATL_DEFENDER_ENABLED=false
ATL_DEFENDER_TENANT_ID=

# ── Output & Logging (optional) ───────────────────────────────────────────────
ATL_LOG_LEVEL=INFO
ATL_LOG_FORMAT=console
ATL_OUTPUT_FORMAT=rich

# ── Multi-tenant / Azure Lighthouse (optional) ────────────────────────────────
# JSON array of workspace objects:
# ATL_SENTINEL_WORKSPACES=[{"workspace_id":"...","workspace_name":"...","resource_group":"...","subscription_id":"...","tenant_id":"..."}]
