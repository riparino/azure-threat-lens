# ──────────────────────────────────────────────────────────────────────────────
# Azure Threat Lens – Environment Configuration Example
# Copy to .env and fill in your values. Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Azure Identity ─────────────────────────────────────────────────────────────
ATL_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
ATL_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
ATL_AZURE_CLIENT_SECRET=your-client-secret-here
ATL_AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# ── Microsoft Sentinel (Primary Workspace) ─────────────────────────────────────
ATL_SENTINEL_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
ATL_SENTINEL_WORKSPACE_NAME=your-workspace-name
ATL_SENTINEL_RESOURCE_GROUP=your-resource-group

# ── Azure Lighthouse – Additional Workspaces (optional) ────────────────────────
# Provide a JSON array of workspace descriptors for multi-tenant / Lighthouse setups.
# The service principal above must have been granted delegated access to each workspace
# via an Azure Lighthouse offer. Leave blank to use primary workspace only.
#
# ATL_SENTINEL_WORKSPACES='[
#   {
#     "workspace_id": "11111111-1111-1111-1111-111111111111",
#     "workspace_name": "client-a-sentinel",
#     "resource_group": "rg-sentinel-clienta",
#     "subscription_id": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
#     "tenant_id": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
#     "display_name": "Client A – Production"
#   },
#   {
#     "workspace_id": "22222222-2222-2222-2222-222222222222",
#     "workspace_name": "client-b-sentinel",
#     "resource_group": "rg-sentinel-clientb",
#     "subscription_id": "cccccccc-cccc-cccc-cccc-cccccccccccc",
#     "display_name": "Client B – Production"
#   }
# ]'
ATL_SENTINEL_WORKSPACES=

# ── Microsoft Graph / Entra ID ─────────────────────────────────────────────────
# Uses the same service principal as Azure Identity above.
# Ensure the SP has the following Graph application permissions:
#   User.Read.All, AuditLog.Read.All, SignInActivity.Read.All

# ── Defender XDR ───────────────────────────────────────────────────────────────
ATL_DEFENDER_TENANT_ID=00000000-0000-0000-0000-000000000000
# Set to true to use Defender API (requires WindowsDefenderATP permissions)
ATL_DEFENDER_ENABLED=false

# ── LLM (Anthropic / Claude) ───────────────────────────────────────────────────
ATL_ANTHROPIC_API_KEY=sk-ant-your-key-here
ATL_LLM_MODEL=claude-sonnet-4-6
ATL_LLM_MAX_TOKENS=4096

# ── Threat Intelligence – Optional ─────────────────────────────────────────────
ATL_VIRUSTOTAL_API_KEY=
ATL_GREYNOISE_API_KEY=
ATL_ABUSEIPDB_API_KEY=

# ── Application Settings ───────────────────────────────────────────────────────
ATL_LOG_LEVEL=INFO
ATL_LOG_FORMAT=console   # console | json
ATL_OUTPUT_FORMAT=rich   # rich | json | plain
ATL_CONFIG_FILE=config/default.yaml
